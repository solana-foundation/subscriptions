    "lint": "pnpm run generate-clients && pnpm --filter @subscriptions/client build && eslint .",
    "lint:fix": "pnpm run generate-clients && pnpm --filter @subscriptions/client build && eslint . --fix"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.4.1",
