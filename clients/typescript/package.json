{
    "name": "@solana/subscriptions",
    "version": "0.4.0-rc.1",
    "description": "TypeScript SDK and @solana/kit plugin for the Subscriptions Solana program: token delegations, recurring payments, and subscription plans.",
    "type": "module",
    "license": "MIT",
    "homepage": "https://github.com/solana-foundation/subscriptions#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solana-foundation/subscriptions.git",
        "directory": "clients/typescript"
    },
    "bugs": {
        "url": "https://github.com/solana-foundation/subscriptions/issues"
    },
    "keywords": [
        "solana",
        "solana-kit",
        "subscriptions",
        "recurring-payments",
        "token-delegation",
        "pinocchio"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run --config vitest.config.ts",
        "test:offline": "vitest run --config vitest.offline.config.ts",
        "clean": "rm -rf dist",
        "clean:generated": "rm -rf src/generated",
        "docs": "npx typedoc"
    },
    "dependencies": {
        "@solana-program/token": "^0.13.0",
        "@solana-program/token-2022": "^0.9.0",
        "@solana/kit-plugin-rpc": "^0.11.1",
        "@solana/kit-plugin-signer": "^0.10.0",
        "@solana/program-client-core": "^6.9.0"
    },
    "peerDependencies": {
        "@solana/kit": "^6.4.0"
    },
    "devDependencies": {
        "@solana-program/system": "^0.12.0",
        "@solana/kit": "^6.9.0",
        "@solana/kit-plugin-litesvm": "^0.10.0",
        "@solana/web3.js": "^1.98.4",
        "@sqds/multisig": "^2.1.4",
        "@swig-wallet/kit": "^2.1.0",
        "@types/node": "^25.7.0",
        "litesvm": "1.1.0",
        "tsup": "^8.3.0",
        "tweetnacl": "^1.0.3",
        "typescript": "^5.7.0",
        "vitest": "^4.1.6"
    }
}
